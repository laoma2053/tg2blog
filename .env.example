# ==================== 应用配置 ====================
APP_ENV=development  # 运行环境：development（开发）/ production（生产）
APP_DEBUG=true       # 调试模式：true（开启）/ false（关闭）

# ==================== 数据库配置 ====================
DB_HOST=127.0.0.1    # 数据库主机（Docker 部署时使用 db）
DB_PORT=3306         # 数据库端口
DB_NAME=tg2blog      # 数据库名称
DB_USER=root         # 数据库用户名
DB_PASSWORD=123456   # 数据库密码（生产环境务必修改）

# ==================== Telegram 配置 ====================
# 获取方式：https://my.telegram.org/apps
TG_API_ID=           # Telegram API ID（必填）
TG_API_HASH=         # Telegram API Hash（必填）
TG_SESSION_NAME=tg2blog  # Session 文件名
TG_CHANNELS=movie_channel_a,movie_channel_b  # 监听的频道列表（逗号分隔）

# ==================== WordPress 配置 ====================
# 注意：WP_BASE_URL 填写站点根地址，不是登录页地址
# 示例：如果登录地址是 https://blog.example.com/wp-login.php
#      那么 WP_BASE_URL 应填写 https://blog.example.com
WP_BASE_URL=https://blog.example.com  # WordPress 站点根地址（必填，用于 REST API 调用）
WP_USERNAME=tg2blog                      # WordPress 用户名（必填，需要有发布文章权限）
WP_APP_PASSWORD=                       # WordPress 应用密码（必填，在后台"用户→个人资料"中生成）

# ==================== 站点配置 ====================
# 注意：对于大多数用户，SITE_BASE_URL 与 WP_BASE_URL 填写相同地址即可
SITE_BASE_URL=https://blog.example.com  # 内容站对外地址（通常与 WP_BASE_URL 相同）
GO_PATH_PREFIX=/go                       # 中间页路径前缀

# ==================== 追剧站配置 ====================
ZHUIJU_BASE_URL=https://www.zhuiju.us  # 搜索站地址

# ==================== 社群入口配置 ====================
QQ_GROUP_URL=https://qm.qq.com/xxxx     # QQ 群链接
QQ_CHANNEL_URL=https://pd.qq.com/xxxx   # QQ 频道链接

# ==================== 备用网盘导流链接 ====================
BACKUP_QUARK_URL=https://...   # 夸克网盘备用入口
BACKUP_BAIDU_URL=https://...   # 百度网盘备用入口
BACKUP_UC_URL=https://...      # UC 网盘备用入口
BACKUP_XUNLEI_URL=https://...  # 迅雷网盘备用入口

# ==================== 重试配置 ====================
RETRY_INTERVAL_MINUTES=30      # WordPress 发布失败后的重试间隔（分钟）
RETRY_BATCH_SIZE=10            # 每次重试处理的资源数量
